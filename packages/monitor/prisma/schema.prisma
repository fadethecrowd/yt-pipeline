generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Pipeline enums (must match root schema exactly) ─────────────────────

enum TopicStatus {
  DISCOVERED
  APPROVED
  SCRIPTED
  REJECTED
  FAILED
}

enum VideoStatus {
  SCRIPT_PENDING
  SCRIPT_DONE
  QUALITY_FAILED
  VOICEOVER_PENDING
  VOICEOVER_DONE
  ASSEMBLY_PENDING
  ASSEMBLY_DONE
  SEO_PENDING
  SEO_DONE
  UPLOAD_PENDING
  UPLOADED
  PUBLISHED
  FAILED
}

// ── Pipeline models (shared DB, read-only from monitor) ─────────────────

model Topic {
  id        String      @id @default(cuid())
  title     String
  url       String      @unique
  source    String
  summary   String?
  score     Float?
  status    TopicStatus @default(DISCOVERED)
  videos    Video[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model Video {
  id             String      @id @default(cuid())
  topicId        String
  topic          Topic       @relation(fields: [topicId], references: [id])
  status         VideoStatus @default(SCRIPT_PENDING)

  scriptJson     Json?
  qualityScore   Int?

  voiceoverUrls  String[]
  voiceoverPath  String?

  videoPath      String?
  videoUrl       String?

  thumbnailA     String?
  thumbnailB     String?
  thumbnailC     String?

  seoTitle       String?
  titleVariantB  String?
  titleVariantC  String?
  seoDescription String?
  seoTags        String[]
  seoChapters    Json?

  youtubeId      String?
  scheduledAt    DateTime?
  publishedAt    DateTime?

  failReason     String?
  retryCount     Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  snapshots      VideoSnapshot[]

  @@index([status])
  @@index([topicId])
  @@index([createdAt])
}

// ── Monitor enums ───────────────────────────────────────────────────────

enum ActionType {
  PIN_COMMENT
  HEART_COMMENT
  REPLY_COMMENT
  UPDATE_TITLE
  UPDATE_DESCRIPTION
  UPDATE_TAGS
  REGENERATE_THUMBNAIL
  COMMUNITY_POST
  END_SCREEN
  REPROMOTE
  ALERT
}

enum ActionStatus {
  PENDING
  AWAITING_APPROVAL
  EXECUTED
  FAILED
  SKIPPED
}

// ── Monitor models ──────────────────────────────────────────────────────

model VideoSnapshot {
  id                    String   @id @default(cuid())
  videoId               String
  video                 Video    @relation(fields: [videoId], references: [id])
  views                 Int
  likes                 Int
  comments              Int
  ctr                   Float?
  impressions           Int?
  avgViewDuration       Float?
  avgViewPercentage     Float?
  estimatedMinutesWatched Float?
  createdAt             DateTime @default(now())

  @@index([videoId, createdAt])
}

model Comment {
  id            String   @id @default(cuid())
  videoId       String
  youtubeCommentId String @unique
  authorName    String
  authorChannel String?
  text          String
  likeCount     Int      @default(0)
  isHearted     Boolean  @default(false)
  isPinned      Boolean  @default(false)
  publishedAt   DateTime
  scrapedAt     DateTime @default(now())

  @@index([videoId, publishedAt])
}

model MonitorAction {
  id         String       @id @default(cuid())
  videoId    String
  type       ActionType
  status     ActionStatus @default(PENDING)
  payload    Json
  reason     String
  result     String?
  createdAt  DateTime     @default(now())
  executedAt DateTime?

  @@index([videoId])
  @@index([status])
}

model DigestLog {
  id         String   @id @default(cuid())
  period     String
  videoCount Int
  summary    String
  sentVia    String
  createdAt  DateTime @default(now())
}

model ChannelGoal {
  id                  String   @id @default(cuid())
  goal                String
  autonomyTier        Int      @default(2)
  bootstrapBenchmarks Json     @default("{\"avgCtr\":4.5,\"avgViewDuration\":40,\"avgViews48hr\":500,\"avgSubsPerVideo\":10}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TopicSeed {
  id        String   @id @default(cuid())
  title     String
  rationale String
  source    String   // e.g. "reddit:r/artificial"
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
