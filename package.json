{
  "name": "yt-pipeline",
  "version": "0.2.0",
  "description": "Automated YouTube content pipeline for AI/Tech news",
  "private": true,
  "main": "dist/index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/pipeline-core && tsc",
    "build:core": "npm run build --workspace=packages/pipeline-core",
    "build:wc": "npm run build --workspace=packages/wc-pipeline",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "pipeline": "tsx src/pipeline.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.3.0",
    "@yt-pipeline/pipeline-core": "*",
    "dotenv": "^17.3.1",
    "googleapis": "^144.0.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
